{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec /usr/bin/uvx serena start-mcp-server --project \"$HOME/src/cfg\""
      ],
      "env": {}
    },
    "ollama": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "ollama-mcp-server"
      ],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    },
    "neovim": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-neovim-server"
      ],
      "env": {
        "NVIM_SOCKET_PATH": "/tmp/nvim.sock",
        "ALLOW_SHELL_COMMANDS": "true"
      }
    },
    "arxiv": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec /usr/bin/uvx arxiv-mcp-server --storage-path \"$HOME/.arxiv-mcp-server/papers\""
      ],
      "env": {}
    },
    "qdrant": {
      "type": "stdio",
      "command": "/usr/bin/uvx",
      "args": [
        "--python",
        "3.13",
        "mcp-server-qdrant"
      ],
      "env": {
        "QDRANT_URL": "http://127.0.0.1:6333",
        "COLLECTION_NAME": "salt-project",
        "EMBEDDING_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      }
    },
    "code-rag": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec \"$HOME/.local/share/pipx/venvs/code-rag/bin/python\" -m code_rag.server"
      ],
      "env": {}
    },
    "blender": {
      "type": "stdio",
      "command": "/usr/bin/uvx",
      "args": [
        "blender-mcp"
      ],
      "env": {}
    },
    "mpd": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec \"$HOME/.local/bin/mpd-mcp-server\""
      ],
      "env": {}
    },
    "hyprland": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec \"$HOME/.local/bin/hyprland-mcp\""
      ],
      "env": {}
    },
    "language-server": {
      "type": "stdio",
      "command": "/usr/bin/env",
      "args": [
        "bash",
        "-lc",
        "exec \"$HOME/.local/bin/mcp-language-server\" --workspace \"$HOME/src/cfg\" --lsp lua-language-server"
      ],
      "env": {}
    },
    "wireshark": {
      "type": "stdio",
      "command": "/usr/bin/uvx",
      "args": [
        "mcp-wireshark"
      ],
      "env": {}
    }
  }
}
