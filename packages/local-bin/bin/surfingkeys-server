#!/usr/bin/env python3

import http.server
import socketserver
import subprocess
import os
import sys
import glob
import traceback
from urllib.parse import urlparse, parse_qs

PORT = int(os.environ.get("SURFINGKEYS_PORT", "18888"))
DIR = os.path.expanduser(os.environ.get("SURFINGKEYS_DIR", "~/.config"))
SET_ZEN_PROXY = os.environ.get("SET_ZEN_PROXY", "set-zen-proxy")


def hyprland_env():
    """Build env with the most recent Hyprland socket signature."""
    hypr_dir = f"/run/user/{os.getuid()}/hypr"
    sockets = glob.glob(os.path.join(hypr_dir, "*"))
    if not sockets:
        return None
    sockets.sort(key=os.path.getmtime, reverse=True)
    env = os.environ.copy()
    env["HYPRLAND_INSTANCE_SIGNATURE"] = os.path.basename(sockets[0])
    return env


class Handler(http.server.SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=DIR, **kwargs)

    def do_GET(self):
        try:
            print(f"=== do_GET called ===", flush=True)
            print(f"Request: {self.path}", flush=True)
            path = self.path.split("?", 1)[0]
            print(f"Path after split: '{path}'", flush=True)
            print(f"Checking if path == '/focus': {path == '/focus'}", flush=True)
            print(f"Checking if path == '/proxy': {path == '/proxy'}", flush=True)

            if path == '/focus':
                print("Entering /focus handler", flush=True)
                try:
                    env = hyprland_env()
                    if env is None:
                        raise RuntimeError("No Hyprland socket found")
                    subprocess.run(
                        ["hyprctl", "dispatch", "sendshortcut", "CTRL,l,activewindow"],
                        env=env,
                        check=True,
                    )
                    self.send_response(200)
                    self.end_headers()
                    self.wfile.write(b'OK')
                except Exception as e:
                    print(f"Error: {e}", flush=True)
                    self.send_response(500)
                    self.end_headers()
                    self.wfile.write(str(e).encode())

            elif path == '/proxy':
                print("Entering /proxy handler", flush=True)
                try:
                    # Parse query string
                    query = urlparse(self.path).query
                    params = parse_qs(query)
                    mode = params.get('mode', [None])[0]
                    print(f"Parsed mode: {mode}", flush=True)
                    if not mode or mode not in ['direct', 'telegram', 'debug', 'system_vpn']:
                        raise ValueError('Invalid or missing mode parameter')

                    # Execute set-zen-proxy (from PATH or SET_ZEN_PROXY env)
                    result = subprocess.run(
                        [SET_ZEN_PROXY, mode],
                        capture_output=True,
                        text=True,
                        check=True
                    )
                    print(f"Command output: {result.stdout}", flush=True)
                    self.send_response(200)
                    self.end_headers()
                    self.wfile.write(result.stdout.encode())
                except Exception as e:
                    print(f"Proxy error: {e}", flush=True)
                    self.send_response(500)
                    self.end_headers()
                    self.wfile.write(str(e).encode())

            else:
                print(f"Path '{path}' not matched, falling back to super().do_GET()", flush=True)
                return super().do_GET()
        except Exception as e:
            print(f"UNEXPECTED ERROR in do_GET: {e}", flush=True)
            print(traceback.format_exc(), flush=True)
            self.send_response(500)
            self.end_headers()
            self.wfile.write(b'Internal server error')

    def end_headers(self):
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Cache-Control", "no-store")
        super().end_headers()

# Allow reuse address to prevent "Address already in use" on restarts
socketserver.TCPServer.allow_reuse_address = True

with socketserver.TCPServer(("", PORT), Handler) as httpd:
    print(f"Serving at port {PORT} from {DIR}")
    httpd.serve_forever()
