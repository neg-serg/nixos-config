#!/usr/bin/env python3
"""Track Hyprland window focus history via IPC and switch to previous window.

Daemon mode (default): listens to activewindowv2/closewindow events on the
Hyprland event socket, maintains an ordered focus history, and writes the
previous window address to a state file.

Switch mode (--switch): reads the state file and focuses the previous window.
"""

from __future__ import annotations

import os
import socket
import subprocess
import sys
import time
from datetime import datetime


_LOG = None


def log(msg: str) -> None:
    global _LOG
    if _LOG is None:
        try:
            _LOG = open("/tmp/hypr-focus-hist.log", "a")
        except OSError:
            return
    ts = datetime.now().strftime("%H:%M:%S.%f")[:-3]
    _LOG.write(f"[{ts}] {msg}\n")
    _LOG.flush()


def socket_dir() -> str:
    sig = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE", "")
    runtime = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    d = f"{runtime}/hypr/{sig}"
    if os.path.isdir(d):
        return d
    return f"/tmp/hypr/{sig}"


def notify(msg: str) -> None:
    subprocess.run(
        ["notify-send", "-a", "hypr-focus-hist", msg],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def state_path() -> str:
    return f"{socket_dir()}/focus-history"


def switch() -> int:
    """Read previous window address from state file and focus it."""
    path = state_path()
    log(f"switch() called, state_path={path}")
    try:
        with open(path) as f:
            addr = f.read().strip()
        log(f"read addr={addr!r}")
    except FileNotFoundError:
        log("state file not found")
        notify("No focus history yet")
        return 1
    if not addr:
        log("empty addr in state file")
        notify("Empty focus history")
        return 1
    result = subprocess.run(
        ["hyprctl", "dispatch", "focuswindow", f"address:{addr}"],
        capture_output=True,
        text=True,
    )
    log(f"hyprctl dispatch rc={result.returncode} stdout={result.stdout.strip()!r} stderr={result.stderr.strip()!r}")
    if result.returncode != 0:
        notify(f"focuswindow failed: {result.stderr.strip()}")
    return result.returncode


def daemon() -> None:
    """Listen to Hyprland events and track focus history, auto-reconnect on failure."""
    path = state_path()

    while True:
        try:
            sd = socket_dir()
            log(f"connecting to socket {sd}/.socket2.sock")
            sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            sock.settimeout(30)
            sock.connect(f"{sd}/.socket2.sock")
            log("connected successfully")
        except Exception as e:
            log(f"connect failed: {type(e).__name__}: {e}")
            notify(f"Cannot connect to Hyprland socket: {e}")
            time.sleep(3)
            continue

        # Ordered list of window addresses, most recent last.
        history: list[str] = []
        total_events = 0

        buf = b""
        try:
            while True:
                data = sock.recv(4096)
                if not data:
                    log("socket closed (empty recv)")
                    break
                total_events += 1
                buf += data
                while b"\n" in buf:
                    line, buf = buf.split(b"\n", 1)
                    event = line.decode(errors="replace")
                    log(f"event #{total_events}: {event[:120]}")

                    if event.startswith("activewindowv2>>"):
                        hex_addr = event[16:]
                        if not hex_addr:
                            log("empty hex_addr, skipping")
                            continue
                        addr = f"0x{hex_addr}"
                        log(f"activewindowv2 addr={addr} history_len={len(history)}")
                        if history and history[-1] == addr:
                            log("same as last, skipping")
                            continue
                        if addr in history:
                            log("addr in history, moving to end")
                            history.remove(addr)
                        history.append(addr)
                        if len(history) > 20:
                            history = history[-20:]
                        if len(history) >= 2:
                            prev = history[-2]
                            log(f"writing state: {prev}")
                            with open(path, "w") as f:
                                f.write(prev)

                    elif event.startswith("closewindow>>"):
                        hex_addr = event[13:]
                        addr = f"0x{hex_addr}"
                        log(f"closewindow addr={addr}")
                        history = [h for h in history if h != addr]
                        if len(history) >= 2:
                            with open(path, "w") as f:
                                f.write(history[-2])
                        elif history:
                            with open(path, "w") as f:
                                f.write(history[0])
                        else:
                            try:
                                os.remove(path)
                            except FileNotFoundError:
                                pass
        except (ConnectionError, OSError) as e:
            log(f"socket error: {e}")
            notify(f"Socket disconnected, reconnecting: {e}")
            continue
        except Exception as e:
            log(f"unexpected error: {e}")
            notify("Unexpected error in focus history daemon, restarting")
            continue
        break


def main() -> int:
    if "--switch" in sys.argv:
        return switch()
    daemon()
    return 0


if __name__ == "__main__":
    sys.exit(main())
