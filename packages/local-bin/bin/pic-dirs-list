#!/bin/sh
# Usage: pic-dirs-list
# pic-dirs-list: index $XDG_PICTURES_DIR dirs with zoxide on changes

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  sed -n '2,2p' "$0" | sed 's/^# \{0,1\}//'; exit 0
fi

[ -n "${XDG_PICTURES_DIR:-}" ] || exit 0
command -v inotifywait >/dev/null 2>&1 || exit 0

# Strip trailing slash if present
dir="${XDG_PICTURES_DIR%/}"

# Initial index on startup
find "$dir" -maxdepth 3 \
  -not -path "$dir/.git/*" \
  -not -path "$dir/.git" -type d -print0 2>/dev/null \
  | xargs -0 -r -I{} sh -c 'command -v zoxide >/dev/null 2>&1 && zoxide add -- "$1" || true' _ {}

# Watch for directory creation/deletion; ISDIR is a flag in the output, not an event name
inotifywait -q -m -e create -e delete "$dir" | while read -r _ events _; do
  case $events in
    *ISDIR*)
      find "$dir" -maxdepth 3 \
        -not -path "$dir/.git/*" \
        -not -path "$dir/.git" -type d -print0 \
        | xargs -0 -r -I {} sh -c 'command -v zoxide >/dev/null 2>&1 && zoxide add -- "$1" || true' _ {}
      ;;
  esac
done
