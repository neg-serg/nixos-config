#!/usr/bin/env zsh
# read_documents: pick and open a document from ~/dw (vicinae dmenu -> zathura)
# Usage: read_documents

IFS=$'\n\t'
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  sed -n '2,3p' "$0" | sed 's/^# \{0,1\}//'; exit 0
fi

command -v fd >/dev/null 2>&1 || { print -u2 'read_documents: fd not found'; :; }
command -v vicinae >/dev/null 2>&1 || { print -u2 'read_documents: vicinae not found'; :; }
command -v zathura >/dev/null 2>&1 || { print -u2 'read_documents: zathura not found'; :; }

sel=$(fd . ~/dw/ -d 1 -t f -e pdf -e djvu -e epub 2>/dev/null \
  | vicinae dmenu -p '⟬doc⟭ ❯>')
[ -n "$sel" ] && zathura "$sel"
