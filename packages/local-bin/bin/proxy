#!/usr/bin/env bash
# proxy — запуск/остановка/обновление Hysteria2 + VLESS Reality прокси
# Usage: proxy [on|off|status|refresh]
set -euo pipefail

CONFIG="$HOME/.config/sing-box-trojan/config.json"
LOG="/tmp/sing-box-trojan.log"

# ============================================================
# bootstrap — создать конфиг с fallback-нодами если нет
# ============================================================
bootstrap() {
    if [ -f "$CONFIG" ]; then return; fi
    echo "  First run: creating config with fallback nodes..."
    mkdir -p "$(dirname "$CONFIG")"
    export CFG_PATH="$CONFIG"
    python3 << 'PYEOF'
import json, os
cfg = {
    "log": {"level": "error"}, "dns": {},
    "inbounds": [{"type": "socks", "tag": "in", "listen": "127.0.0.1", "listen_port": 10808}],
    "outbounds": [
        {"type": "hysteria2", "tag": "h2-ro",
         "server": "85.120.228.208", "server_port": 47257,
         "password": "35415e5e-3666-4454-8c45-903af0fcddf4",
         "tls": {"enabled": True, "insecure": True, "server_name": "www.bing.com"}},
        {"type": "vless", "tag": "vl-dallas",
         "server": "84.32.45.56", "server_port": 8443,
         "uuid": "96fdf2ec-8f42-4735-a176-1578c5d5ea67", "packet_encoding": "xudp",
         "tls": {"enabled": True, "server_name": "www.yahoo.com",
                 "utls": {"enabled": True, "fingerprint": "chrome"},
                 "reality": {"enabled": True,
                            "public_key": "V2DnHta7YKXsdC6St2X2seosnXJe08070FAT-nNVLUg",
                            "short_id": "7585110041ceb2c1"}}},
        {"type": "vless", "tag": "vl-houston",
         "server": "216.126.238.95", "server_port": 443,
         "uuid": "a468ba45-559c-46cc-8b51-a2f0b86b21d4", "packet_encoding": "xudp",
         "tls": {"enabled": True, "server_name": "icloud.com",
                 "utls": {"enabled": True, "fingerprint": "chrome"},
                 "reality": {"enabled": True,
                            "public_key": "9xSqgLlPxZJIIOBdBvRTWmIXJRG5Z9hj1uQWEvfNlUM",
                            "short_id": "46ed"}}},
        {"type": "urltest", "tag": "auto",
         "outbounds": ["h2-ro", "vl-dallas", "vl-houston"],
         "interval": "5m", "tolerance": 50},
        {"type": "direct", "tag": "direct"}
    ],
    "route": {"rules": [{"ip_is_private": True, "outbound": "direct"}],
              "final": "auto", "auto_detect_interface": True}
}
p = os.environ["CFG_PATH"]
os.makedirs(os.path.dirname(p), exist_ok=True)
with open(p, "w") as f:
    json.dump(cfg, f, indent=2)
print("  Done: 1 Hysteria2 + 2 VLESS Reality")
PYEOF
}

# ============================================================
# refresh — скачать свежие ноды, обновить конфиг
# ============================================================
refresh() {
    echo "  Fetching fresh nodes..."
    FALLBACK_NODES=$(cat << 'NODES'
hysteria2://35415e5e-3666-4454-8c45-903af0fcddf4@85.120.228.208:47257?insecure=1&sni=www.bing.com
vless://96fdf2ec-8f42-4735-a176-1578c5d5ea67@84.32.45.56:8443?encryption=none&security=reality&sni=www.yahoo.com&fp=chrome&pbk=V2DnHta7YKXsdC6St2X2seosnXJe08070FAT-nNVLUg&sid=7585110041ceb2c1
vless://a468ba45-559c-46cc-8b51-a2f0b86b21d4@216.126.238.95:443?encryption=none&security=reality&sni=icloud.com&fp=chrome&pbk=9xSqgLlPxZJIIOBdBvRTWmIXJRG5Z9hj1uQWEvfNlUM&sid=46ed
NODES
)
    NEW_NODES=""
    for url in \
      "https://raw.githubusercontent.com/rtwo2/FastNodes/main/sub/protocols/vless.txt" \
      "https://raw.githubusercontent.com/rtwo2/FastNodes/main/sub/everything.txt"; do
        data=$(curl --noproxy '*' -sL --connect-timeout 5 --max-time 10 "$url" 2>/dev/null | \
          grep -E '^(vless|hysteria2)://' | head -10 || true)
        if [ -n "$data" ]; then
            echo "    $(echo "$data" | wc -l) from $(basename $url)"
            NEW_NODES="$NEW_NODES"$'\n'"$data"
        fi
    done

    ALL="$FALLBACK_NODES"
    [ -n "$NEW_NODES" ] && ALL="$FALLBACK_NODES"$'\n'"$NEW_NODES"
    export NODES_TEXT="$ALL"
    export CFG_PATH="$CONFIG"
    python3 << 'PYEOF'
import json, os, urllib.parse
text = os.environ["NODES_TEXT"]
cfg_path = os.environ["CFG_PATH"]
outbounds = []
def clean(s):
    if not s: return {}
    s = s.replace('&amp;', '&')
    if '#' in s: s = s.split('#')[0]
    return {k: v[0].split('#')[0] for k, v in urllib.parse.parse_qs(s).items()}
for line in text.strip().split('\n'):
    line = line.strip()
    if not line: continue
    try:
        if line.startswith('hysteria2://'):
            r = line.split('hysteria2://')[1]
            pwd = r.split('@')[0] if '@' in r else r.split('?')[0]
            a = r.split('@', 1)[1] if '@' in r else r
            h = a.split('?')[0]; host = h.split(':')[0]
            ps = h.split(':')[1] if ':' in h else '443'
            port = int(ps.split('?')[0]) if ps.split('?')[0].isdigit() else 443
            p = clean(a.split('?', 1)[1] if '?' in a else '')
            ob = {"type": "hysteria2", "tag": f"h2-{len(outbounds)}",
                  "server": host, "server_port": port, "password": pwd,
                  "tls": {"enabled": True, "insecure": True,
                          "server_name": p.get('sni', host)}}
            if 'obfs' in p:
                ob["obfs"] = {"type": p['obfs'], "password": p.get('obfs-password', '')}
            outbounds.append(ob)
        elif line.startswith('vless://'):
            r = line.split('vless://')[1]
            uuid = r.split('@')[0]
            a = r.split('@', 1)[1] if '@' in r else r
            hp = a.split('?')[0]
            host = hp.rsplit(':', 1)[0]; port = int(hp.rsplit(':', 1)[1])
            p = clean(a.split('?', 1)[1] if '?' in a else '')
            ob = {"type": "vless", "tag": f"vl-{len(outbounds)}",
                  "server": host, "server_port": port, "uuid": uuid,
                  "packet_encoding": "xudp"}
            tls = {"enabled": True, "server_name": p.get('sni', host),
                   "utls": {"enabled": True, "fingerprint": p.get('fp', 'chrome')}}
            if p.get('security') == 'reality':
                tls["reality"] = {"enabled": True,
                                 "public_key": p.get('pbk', ''),
                                 "short_id": p.get('sid', '')}
            ob["tls"] = tls; outbounds.append(ob)
    except: pass
tags = [o["tag"] for o in outbounds]
if tags:
    outbounds.append({"type": "urltest", "tag": "auto",
                      "outbounds": tags, "interval": "5m", "tolerance": 50})
outbounds.append({"type": "direct", "tag": "direct"})
cfg = {"log":{"level":"error"},"dns":{},
       "inbounds":[{"type":"socks","tag":"in","listen":"127.0.0.1","listen_port":10808}],
       "outbounds":outbounds,
       "route":{"rules":[{"ip_is_private":True,"outbound":"direct"}],
                "final":"auto","auto_detect_interface":True}}
os.makedirs(os.path.dirname(cfg_path), exist_ok=True)
with open(cfg_path,"w") as f:
    json.dump(cfg, f, indent=2)
print(f"  Config: {len(outbounds)-2} outbounds + urltest")
PYEOF
}

# ============================================================
# start/stop
# ============================================================
start() {
    if systemctl is-active --quiet xray.service 2>/dev/null; then
        echo "  Stopping xray..."
        sudo systemctl stop xray.service
    fi
    pkill -f 'sing-box.*trojan' 2>/dev/null || true
    sleep 1
    export ENABLE_DEPRECATED_LEGACY_DNS_SERVERS=true
    nohup sing-box run -c "$CONFIG" > "$LOG" 2>&1 &
    sleep 2
    if pgrep -f 'sing-box.*trojan' > /dev/null 2>&1; then
        echo "  Proxy on 127.0.0.1:10808"
        echo "  Dashboard: http://127.0.0.1:9090 (secret: neg)"
    else
        echo "  FAILED"
        tail -3 "$LOG" 2>/dev/null || true
    fi
}

stop() {
    pkill -f 'sing-box.*trojan' 2>/dev/null || true
    echo "  Stopped. Restore xray: sudo systemctl start xray"
}

# ============================================================
# main
# ============================================================
case "${1:-status}" in
    on|start)    bootstrap; start ;;
    off|stop)    stop ;;
    refresh)     refresh; start ;;
    status)
        if pgrep -f 'sing-box.*trojan' > /dev/null 2>&1; then
            echo "Proxy: RUNNING (Hysteria2 + VLESS Reality)"
            ss -tlnp 2>/dev/null | grep -E '10808|10810' || true
        else
            echo "Proxy: STOPPED"
        fi
        if systemctl is-active --quiet xray.service 2>/dev/null; then
            echo "Xray: RUNNING"
        else
            echo "Xray: STOPPED"
        fi
        ;;
    *) echo "Usage: $0 {on|off|status|refresh}"; exit 1 ;;
esac
